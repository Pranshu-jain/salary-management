# Railway sets DATABASE_URL automatically when you add the PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/salary_management_production

# Generate with: ruby -e "require 'securerandom'; puts SecureRandom.hex(64)"
SECRET_KEY_BASE=your_64_char_hex_secret_here

# Rails environment
RAILS_ENV=production

# CORS — set to your Vercel frontend URL after deploying
# Use comma-separated values for multiple origins
ALLOWED_ORIGINS=https://your-app.vercel.app

# Optional: override thread count (default 5)
# RAILS_MAX_THREADS=5
